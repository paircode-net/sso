@using BAYSOFT.Core.Domain.Default.Samples.Entity
@using BAYSOFT.Web.Blazor.Components.Pages.Default.Samples.Components
@using Microsoft.Extensions.Localization

@page "/default/samples/{sampleId:guid}"

@rendermode InteractiveServer

<PageSample
	RootEndPoint="@GetRootEndPoint()"
	Id="SampleId">
</PageSample>

@code {
	[Parameter] public Guid? SampleId { get; set; }
	public string GetRootEndPoint()
	{
        return $"/default/samples";
	}
}