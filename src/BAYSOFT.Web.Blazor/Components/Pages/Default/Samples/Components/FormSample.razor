@using BAYSOFT.Core.Application.Default.Samples.Commands;
@using BAYSOFT.Core.Application.Default.Samples.Queries;
@using BAYSOFT.Core.Domain.Default.Samples.Entity;
@using BAYSOFT.Web.Blazor.Extensions;
@using Microsoft.Extensions.Localization;
@using ModelWrapper.Extensions.GetModel;
@using ModelWrapper.Extensions.GetModels;
@using System.ComponentModel.DataAnnotations;

@inject IServiceScopeFactory scope
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IStringLocalizer<Sample> Localizer

<EditForm Model="@Model" @ref="EditForm" OnValidSubmit="OnValidSubmit">
	<DataAnnotationsValidator />
	<ValidationSummary />
	<MudGrid>

		<MudItem xs="12"><MudTextField Label="@Localizer["Description"]" Variant="Variant.Outlined" @bind-Value="Model.Description" For="@(() => Model.Description)" /></MudItem>


		@if (!(Wrapped.HasValue && Wrapped.Value))
		{
			<MudItem xs="12" Class="d-flex justify-end flex-grow-1 gap-4">
				<MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Class="ml-auto">@Localizer["Save"]</MudButton>
			</MudItem>
		}
	</MudGrid>
</EditForm>

@code {
	[Parameter] public Guid? Id { get; set; }

	[Parameter] public bool? Wrapped { get; set; }
	[Parameter] public EventCallback<Sample> OnSaveCallback { get; set; }
	[Parameter] public RenderFragment? ChildContent { get; set; }

	private FormSampleModel Model { get; set; }
	private EditForm EditForm { get; set; }
	private bool Success { get; set; }

	public FormSample()
	{
		Model = new ();
	}

	protected override async Task OnInitializedAsync()
	{
		if (Id.HasValue)
		{
			var query = new GetSampleByIdQuery();
			query.Project(m => m.Id = Id.Value);
			var response = await scope.SendInNewScope(query);

			if (response.HandleNotifications(Snackbar, false))
			{
				var domain = response.GetModel();
				Model = new (domain);
				StateHasChanged();
			}
		}
		else
		{
			Model = new ();
		}
	}

	private async Task OnValidSubmit(EditContext context)
	{
		if (!Id.HasValue)
			await Create(context);
		else
			await Update(Id.Value, context);
	}

	private async Task Create(EditContext context)
	{
		var command = new PostSampleCommand();
		var formModel = (FormSampleModel)context.Model;

		command.Project(model => formModel.ToDomain(model));

		var response = await scope.SendInNewScope(command);

		if (response.HandleNotifications(Snackbar))
		{
			Success = true;
			StateHasChanged();
			await this.OnSaveCallback.InvokeAsync(response.GetModel());
		}
	}

	private async Task Update(Guid id, EditContext context)
	{
		var command = new PutSampleCommand();
		var formModel = (FormSampleModel)context.Model;

		command.Project(model => formModel.ToDomain(model, id));

		var response = await scope.SendInNewScope(command);

		if (response.HandleNotifications(Snackbar))
		{
			Success = true;
			StateHasChanged();
			await this.OnSaveCallback.InvokeAsync(response.GetModel());
		}
	}

	public async Task Save()
	{
		if (EditForm != null && EditForm.EditContext != null && EditForm.EditContext.Validate())
		{
			await OnValidSubmit(EditForm.EditContext);
		}
	}

	public class FormSampleModel
	{
        [Required(ErrorMessage = "{0} é obrigatório!")]        public string? Description { get; set; }
		public FormSampleModel() { }
		public FormSampleModel(Sample entity)
		{
            Description = entity.Description;
		}
		public Sample ToDomain(Sample entity, Guid? id = default(Guid?))
		{
			if (entity == null)
				entity = new();

			if (id.HasValue)
				entity.Id = id.Value;

            entity.Description = Description;
			return entity;
		}
	}
}