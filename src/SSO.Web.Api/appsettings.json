{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Sso": {
    "Database": {
      "AutoMigrate": true,
      "SeedOnStartup": true
    },
    "Cors": {
      "Enabled": true,
      "AllowedOrigins": [ "https://localhost:5001", "https://localhost:3000" ]
    },
    "RateLimit": {
      "Enabled": true,
      "PermitLimit": 60,
      "WindowSeconds": 60
    },
    "Lockout": {
      "AllowedForNewUsers": true,
      "MaxFailedAccessAttempts": 5,
      "DefaultLockoutMinutes": 5
    },
    "Signing": {
      "UseDevelopmentCertificates": true,
      "CertificatePath": "",
      "CertificatePassword": "",
      "KeyVaultUri": "",
      "KeyVaultCertificateName": ""
    },
    "Observability": {
      "Enabled": true,
      "Exporter": "Console",
      "OtlpEndpoint": "http://localhost:4317",
      "AzureMonitorConnectionString": "",
      "TracingEnabled": true,
      "MetricsEnabled": true,
      "TracingSampleRatio": 1.0,
      "SerilogRequestLogging": true
    },
    "ExternalAuth": {
      "Entra": {
        "Enabled": false,
        "TenantId": "common",
        "ClientId": "",
        "ClientSecret": "",
        "CallbackPath": "/signin-entra"
      },
      "Google": {
        "Enabled": false,
        "ClientId": "",
        "ClientSecret": "",
        "CallbackPath": "/signin-google"
      },
      "Ldap": {
        "Enabled": false,
        "Host": "",
        "Port": 389,
        "BaseDn": ""
      }
    }
  }
}
