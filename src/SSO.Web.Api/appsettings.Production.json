{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Sso": {
    "Database": {
      "AutoMigrate": false,
      "SeedOnStartup": false
    },
    "Cors": {
      "Enabled": true,
      "AllowedOrigins": []
    },
    "RateLimit": {
      "Enabled": true,
      "PermitLimit": 30,
      "WindowSeconds": 60
    },
    "Signing": {
      "UseDevelopmentCertificates": false,
      "CertificatePath": "",
      "CertificatePassword": ""
    },
    "ExternalAuth": {
      "Entra": {
        "Enabled": false,
        "TenantId": "",
        "ClientId": "",
        "ClientSecret": ""
      },
      "Google": {
        "Enabled": false
      },
      "Ldap": {
        "Enabled": false
      }
    }
  }
}
