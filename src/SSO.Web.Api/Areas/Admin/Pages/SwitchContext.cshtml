@page
@model SSO.Web.Api.Areas.Admin.Pages.SwitchContextModel
@{
	ViewData["Title"] = "Contexto";
}
<h1>Trocar contexto</h1>
<p class="meta">Equivalente server-side ao grant <code>switch_context</code> (ADR-003).</p>
@if (!string.IsNullOrEmpty(Model.Message)) { <div class="flash">@Model.Message</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="flash error">@Model.Error</div> }
<div class="card">
	<form method="post">
		<label>Organização</label>
		<select asp-for="OrganizationId">
			@foreach (var org in Model.Organizations)
			{
				<option value="@org.Id">@org.Name (@org.Code)</option>
			}
		</select>
		<label>Filial (opcional)</label>
		<select asp-for="BranchId">
			<option value="">(org-wide)</option>
			@foreach (var b in Model.Branches)
			{
				<option value="@b.Id">@b.Name (@b.Code)</option>
			}
		</select>
		<p style="margin-top:1rem"><button type="submit">Aplicar contexto</button></p>
	</form>
</div>
