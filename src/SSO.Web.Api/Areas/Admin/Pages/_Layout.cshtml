@using SSO.Middleware.Identity
@inject IAdminPortalContextService Portal
<!DOCTYPE html>
<html lang="pt-BR">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>@ViewData["Title"] — SSO Admin</title>
	<style>
		:root { --bg:#0f1419; --panel:#1a222c; --text:#e7ecf1; --muted:#9aa7b5; --accent:#3d8bfd; --line:#2a3542; --ok:#3dd68c; --warn:#f5a524; }
		* { box-sizing: border-box; }
		body { margin:0; font-family: "Segoe UI", system-ui, sans-serif; background: var(--bg); color: var(--text); }
		a { color: var(--accent); text-decoration: none; }
		a:hover { text-decoration: underline; }
		.shell { display:grid; grid-template-columns: 240px 1fr; min-height: 100vh; }
		nav { background: var(--panel); border-right: 1px solid var(--line); padding: 1.25rem 1rem; }
		nav .brand { font-weight: 700; letter-spacing: .04em; margin-bottom: 1.5rem; }
		nav a { display:block; padding: .45rem .6rem; border-radius: 6px; color: var(--text); margin-bottom: .25rem; }
		nav a:hover { background: #243040; text-decoration: none; }
		main { padding: 1.5rem 2rem; }
		.meta { color: var(--muted); font-size: .9rem; margin-bottom: 1rem; }
		.card { background: var(--panel); border: 1px solid var(--line); border-radius: 10px; padding: 1rem 1.25rem; margin-bottom: 1rem; }
		table { width:100%; border-collapse: collapse; }
		th, td { text-align:left; padding: .55rem .4rem; border-bottom: 1px solid var(--line); font-size: .95rem; }
		th { color: var(--muted); font-weight: 600; }
		label { display:block; margin: .5rem 0 .25rem; color: var(--muted); font-size: .85rem; }
		input, select, button, textarea { width:100%; max-width: 420px; padding: .5rem .65rem; border-radius: 6px; border: 1px solid var(--line); background:#121820; color: var(--text); }
		button, .btn { background: var(--accent); border: none; color: white; cursor: pointer; font-weight: 600; width: auto; display: inline-block; padding: .5rem .9rem; }
		.btn-secondary { background: #334155; }
		.flash { padding: .75rem 1rem; border-radius: 8px; margin-bottom: 1rem; background: #143528; color: var(--ok); }
		.error { background: #3a1d1d; color: #ff8e8e; }
		.grid-2 { display:grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
		@@media (max-width: 900px) { .shell { grid-template-columns: 1fr; } .grid-2 { grid-template-columns: 1fr; } }
	</style>
</head>
<body>
	<div class="shell">
		<nav>
			<div class="brand">SSO Admin</div>
			<a asp-area="Admin" asp-page="/Index">Início</a>
			<a asp-area="Admin" asp-page="/SwitchContext">Contexto</a>
			@if (Portal.HasPermission(SSO.Shared.Identity.SsoAdminPermissions.Org) || Portal.IsPlatformAdmin)
			{
				<a asp-area="Admin" asp-page="/Branches">Filiais</a>
				<a asp-area="Admin" asp-page="/Invites">Convites</a>
			}
			@if (Portal.IsPlatformAdmin)
			{
				<a asp-area="Admin" asp-page="/Organizations">Organizações</a>
				<a asp-area="Admin" asp-page="/Products">Produtos</a>
				<a asp-area="Admin" asp-page="/Permissions">Permissões</a>
			}
			@if (Portal.HasPermission(SSO.Shared.Identity.SsoAdminPermissions.AuditRead))
			{
				<a asp-area="Admin" asp-page="/Audit">Auditoria</a>
			}
			<a href="/Account/Login">Sair / Login</a>
		</nav>
		<main>
			@RenderBody()
		</main>
	</div>
</body>
</html>
